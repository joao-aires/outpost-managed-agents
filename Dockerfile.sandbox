# High-performance, secure sandbox environment for KubeCMA agent execution
FROM golang:1.21-bullseye AS go-builder

# Install Anthropic CLI
RUN go install github.com/anthropics/anthropic-cli/cmd/ant@latest

# Final execution image
FROM debian:bookworm-slim

# Install system utilities, python, nodejs, and development libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    make \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    nodejs \
    npm \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Copy the precompiled ant CLI binary from the go builder
COPY --from=go-builder /go/bin/ant /usr/local/bin/ant

# Create non-root agent user and setting up directory permissions
RUN groupadd -g 1000 agent && \
    useradd -u 1000 -g agent -m -s /bin/bash agent

# Setup workspace
WORKDIR /workspace
RUN chown -R agent:agent /workspace

# Switch to non-root agent user
USER agent

# Initialize a default virtual environment for python tools inside workspace
RUN python3 -m venv /workspace/.venv
ENV PATH="/workspace/.venv/bin:$PATH"

# Run infinite block to keep pod running (FastAPI will execute commands within this pod)
CMD ["tail", "-f", "/dev/null"]
